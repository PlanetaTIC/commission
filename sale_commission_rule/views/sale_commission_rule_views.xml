<odoo>

    <record model="ir.ui.view" id="view_sale_commission_rule">
        <field name="name">Sales commission rules tree</field>
        <field name="model">sale.commission.rule</field>
        <field name="arch" type="xml">
            <tree string="Commission rules" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="agent" options="{'no_create': True}"/>
                <field name="customer" options="{'no_create': True}"/>
                <field name="category" options="{'no_create': True}"/>
                <field name="product" options="{'no_create': True}"/>
                <field name="commission" options="{'no_create': True}"/>
            </tree>
        </field>
    </record>

    <record model="ir.ui.view" id="view_sale_commission_rule_search">
        <field name="name">Sales commission rules search</field>
        <field name="model">sale.commission.rule</field>
        <field name="arch" type="xml">
            <search string="Commission rules search">
                <field name="agent"/>
                <field name="customer"/>
                <field name="category"/>
                <field name="product"/>
                <field name="commission"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="Agent" name="group_agent" context="{'group_by': 'agent'}"/>
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
                    <filter string="Product" name="group_product" context="{'group_by': 'product'}"/>
                    <filter string="Commission" name="group_commission" context="{'group_by': 'commission'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_sale_commission_rule">
        <field name="name">Commission rules</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.commission.rule</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem name="Commission rules"
              id="menu_sale_commission_rule"
              parent="sale_commission.menu_sale_commissions_management"
              action="action_sale_commission_rule"
              groups="sales_team.group_sale_manager"
              sequence="5"
    />

</odoo>
