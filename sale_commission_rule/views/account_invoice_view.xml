<odoo>

    <record id="invoice_form_agent" model="ir.ui.view">
        <field name="name">account.invoice.form.agent.rules</field>
        <field name="model">account.invoice</field>
        <field name="inherit_id" ref="sale_commission.invoice_form_agent"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/tree//field[@name='agents']" position="inside">
                <!-- hack to make on change product work -->
                <!-- it breaks form view -->
                <tree>
                    <field name="agent"/>
                    <field name="commission"/>
                </tree>
            </xpath>
        </field>
    </record>

    <record id="invoice_line_form_agent" model="ir.ui.view">
        <field name="name">account.invoice.line.form.agent.rules</field>
        <field name="model">account.invoice.line</field>
        <field name="inherit_id" ref="sale_commission.invoice_line_form_agent"/>
        <field name="arch" type="xml">
            <field name="agents" position="inside">
                <!-- hack to fetch agents again and fix form view -->
                <form/>
            </field>
        </field>
    </record>

    <record id="view_account_invoice_line_agent_only" model="ir.ui.view">
        <field name="name">account.invoice.line.form.agent.only</field>
        <field name="model">account.invoice.line</field>
        <field name="priority" eval="32"/>
        <field name="arch" type="xml">
            <form>
                <!-- hack to make on change agent work -->
                <field name="invoice_id" invisible="1"/>
                <field name="product_id" invisible="1"/>

                <field name="commission_free" invisible="1"/>
                <field name="agents" attrs="{'readonly': [('commission_free', '=', True)]}"/>
                <footer class="oe_edit_only">
                    <button string="Save" special="save" class="oe_highlight"/>
                    <button string="Discard" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
