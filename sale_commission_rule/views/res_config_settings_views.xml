<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale_commission_rule</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@data-key='sale_management']" position="inside">
                <h2>Commissions</h2>
                <div id="sales_settings_commissions"
                     class="row mt16 o_settings_container">
	                <div id="sales_settings_commission_rule_priority"
	                     class="col-12 col-lg-6 o_setting_box">
	                    <div class="o_setting_right_pane">
	                        <label for="sale_commission_rule_priority" string="Rules priority"/>
	                        <div class="text-muted">
	                            Priority when more than one rule applies
	                        </div>
	                        <div class="content-group">
	                            <div class="mt16">
	                                <field name="sale_commission_rule_priority" class="o_light_label" widget="radio"/>
	                            </div>
	                        </div>
	                    </div>
	                </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
